	function getItems(catid) {
		var catalog = $sp.getValue('sc_catalog');
		var scRecord = new sn_sc.CatalogSearch().search(catalog, catid, '', false, true);
		scRecord.addQuery('sys_class_name', 'NOT IN', 'sc_cat_item_wizard');
		scRecord.addEncodedQuery('hide_sp=false^ORhide_spISEMPTY');
		scRecord.orderBy('order');
		scRecord.orderBy('name');
		scRecord.query();

		var items = data.items = [];
		while (scRecord.next()) {
			var catalogItemJS = new sn_sc.CatItem(scRecord.getUniqueValue());
			if (!catalogItemJS.canView() || !catalogItemJS.isVisibleServicePortal())
				continue;
			var catItemDetails = catalogItemJS.getItemSummary();

			var item = {};
			item.name = catItemDetails.name;
			item.short_description = catItemDetails.short_description;
			item.picture = catItemDetails.picture;
			item.price = catItemDetails.price;
			item.sys_id = catItemDetails.sys_id;
			item.hasPrice = catItemDetails.show_price;
			item.page = 'bu_cat_item';
			item.type = catItemDetails.type;
			item.order = catItemDetails.order;
			item.sys_class_name = catItemDetails.sys_class_name;
			if (item.type == 'order_guide') {
				item.page = 'sc_cat_item_guide';
			} else if (item.sys_class_name == 'sc_cat_item_content') {
				var contentItem = new GlideRecord('sc_cat_item_content');
				contentItem.get(item.sys_id.toString());
				item.content_type = contentItem.content_type.toString();
				item.url = contentItem.url.toString();
				if (contentItem.content_type == 'kb') {
					item.kb_article = catItemDetails.kb_article.toString();
					item.page = 'bu_kb_article';
					item.sys_id = item.kb_article.toString();
				} else if (contentItem.content_type == 'external') {
					item.target = '_blank';
				}
				else if (contentItem.content_type == 'literal') {
					item.content_type = 'literal'
				}
			}
			items.push(item);
		}
		return items;
	}
	function getSingleCategoryDetails(catID) {
		var categoriesList = [];
		var categoriesGr = new GlideRecord('sc_category');
		categoriesGr.addQuery("sc_catalog", data.catalog);
		if (catID)
			categoriesGr.addQuery("sys_id", catID);
		if(data.isPPE =="true")
			categoriesGr.addEncodedQuery("sc_catalog=e0d08b13c3330100c8b837659bba8fb4^titleLIKEppe");
		categoriesGr.addActiveQuery();
		categoriesGr.orderBy('order');
		categoriesGr.orderBy('title');
		categoriesGr.query();
		while (categoriesGr.next()) {
			var categoryJS = new sn_sc.CatCategory(categoriesGr.getUniqueValue() + '');
			//if (!categoryJS.canView())
			//continue;
			var categoryDetails = {};
			categoryDetails.title = categoryJS.getTitle();
			categoryDetails.description = categoryJS.getDescription();
			categoryDetails.full_description = categoryJS.getFullDescription();
			categoryDetails.icon = categoryJS.getIconSRC();
			categoryDetails.header_icon = categoryJS.getHeaderIconSRC();
			categoryDetails.homepage_image = categoryJS.getHomepageImageSRC();
			categoryDetails.sys_id = categoryJS.getID();
			categoryDetails.subcategories = getCategoryDetails(categoryJS.getID());
			categoryDetails.items = getItems(categoryJS.getID().toString());
			categoriesList.push(categoryDetails);
		}
		return categoriesList;
	}
	//gs.addInfoMessage(JSON.stringify(data.categoriesList));
