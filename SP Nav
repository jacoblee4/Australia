function($scope, $location, $timeout, $window, $document, $rootScope, spUtil, spAriaUtil) {
	var c = this;
	var ITEM_LIMIT = 9;
	$scope.page = 1;
	$scope.totalItems = $scope.data.items;
	$scope.displayItems = $scope.totalItems.slice(0, ITEM_LIMIT);
	$scope.pageChanged = function () {
		var startPos = ($scope.page - 1) * ITEM_LIMIT;
		//$scope.displayItems = $scope.totalItems.slice(startPos, startPos + 3);
		console.log($scope.page + "---" + startPos);
	};
	$scope.selectedItem = false;
	$scope.view = 'grid';
	$scope.showItem = false;

	/** Check if there are url parms */
	// Category
	if (c.data.urlCategory != '') {
		var temp_category = getCategoryObject(c.data.urlCategory);
		if (temp_category != '') {
			$scope.selectedCategory = temp_category;
			$scope.data.showTitle = false;
			c.subcategories = temp_category.subcategories;
			c.items = [];
			$scope.totalItems = temp_category.items;
			$scope.displayItems = $scope.totalItems.slice(0, ITEM_LIMIT);
			if (!c.subcategories || c.subcategories.length == 0) {
				c.noSub = true;
			}
			$scope.showItem = false;
		}
	}
	// Subcategory
	if (c.data.urlCategory != '' && c.data.urlSubcategory != '') {
		var temp_subcategory = getSubcategoryObject(c.data.urlCategory, c.data.urlSubcategory);
		if (temp_subcategory != '') {
			$scope.selectedSubCategory = temp_subcategory;
			c.childcategories = temp_subcategory.subcategories;
			c.items = [];
			//c.items = subcategory.items;
			$scope.totalItems = temp_subcategory.items;
			$scope.displayItems = $scope.totalItems.slice(0, ITEM_LIMIT);
			$scope.showItem = false;
			c.isMobile = false;
		}
	}
	// Catalog Item
	if (c.data.urlCategory != '' && c.data.urlCatItem != '') {
		var temp_item = getCatItemObject(c.data.urlCategory, c.data.urlSubcategory, c.data.urlCatItem);
		c.subcategories = [];
		$scope.selectedItem = true;
		var kbOptions = { sys_id: temp_item.sys_id.toString(), display_cart_on_right: 'false' };
		if (temp_item.type == "order_guide") {
			spUtil.get("bku-widget-sc-order-guide-v2", kbOptions).then(function (response) {
				c.itemWidgets = [response];
			});
		}
		else {
			spUtil.get("bu-cat-item", kbOptions).then(function (response) {
				c.itemWidgets = [response];
			});
		}

		$scope.showItem = true;
	}

	$scope.selectCategory = function (category) {
		$scope.selectedCategory = category;
		$scope.selectedSubCategory = null;
		$scope.selectedItemObj = null;
		$scope.data.showTitle = false;
		c.subcategories = category.subcategories;
		c.items = [];
		$scope.totalItems = category.items;
		$scope.displayItems = $scope.totalItems.slice(0, ITEM_LIMIT);
		if (!c.subcategories || c.subcategories.length == 0) {
			c.noSub = true;
		}
		$scope.showItem = false;
	};
	$scope.selectSubCategory = function (subcategory) {
		$scope.selectedSubCategory = subcategory;
		$scope.selectedItemObj = null;
		c.childcategories = subcategory.subcategories;
		c.items = [];
		//c.items = subcategory.items;
		$scope.totalItems = subcategory.items;
		$scope.displayItems = $scope.totalItems.slice(0, ITEM_LIMIT);
		$scope.showItem = false;
		c.isMobile = false;
	};
	$scope.selectChildCategory = function (childcat) {
		$scope.selectedChildCategory = childcat;
		c.items = [];
		//c.items = childcat.items;
		$scope.totalItems = childcat.items;
		$scope.displayItems = $scope.totalItems.slice(0, ITEM_LIMIT);
		$scope.showItem = false;
		c.isMobile = false;
		c.isChildMobile = true;
	};
	$scope.back = function () {
		c.isChildMobile = false;
		if ($scope.showItem == true)
			$scope.showItem = false;
		c.noSub = false;
		c.childcategories = [];
		c.subcategories = [];
		c.isMobile = true;
	};
	$scope.reset = function () {
		var tme = Math.floor(Date.now() / 1000);
		$location.search("update", tme);
	};
	$scope.toggleCategories = function () {
		c.isMobile = true;
	};

	$scope.changeView = function (view) {
		$scope.view = view;
	};

	$scope.isTouchDevice = function () {
		return ('ontouchstart' in $window);
	};
	$scope.selectItem = function (catItem) {
		c.subcategories = [];
		$scope.selectedItem = true;
		$scope.selectedItemObj = catItem;
		var kbOptions = { sys_id: catItem.sys_id.toString(), display_cart_on_right: 'false' };
		if (catItem.sys_class_name == 'sc_cat_item_content') {
			if (catItem.content_type == 'literal') {
				spUtil.get("bu-cat-item", kbOptions).then(function (response) {
					c.itemWidgets = [response];
				});
			}
			else {
				top.location.href = catItem.url;
			}
		}
		else if (catItem.type == "order_guide") {
			console.log(kbOptions)
			spUtil.get("bku-widget-sc-order-guide-v2", kbOptions).then(function (response) {
				c.itemWidgets = [response];
			});
		}
		else {
			spUtil.get("bu-cat-item", kbOptions).then(function (response) {
				c.itemWidgets = [response];
			});
		}

		$scope.showItem = true;
	};

	$scope.copyLinkToClipboard = function () {
		var link_input = document.getElementById('cat-item-link');
		var url_parms = '';
		if ($scope.selectedCategory.sys_id) {
			url_parms += '&cat=' + $scope.selectedCategory.sys_id;
		}
		if ($scope.selectedSubCategory && $scope.selectedSubCategory.sys_id) {
			url_parms += '&subcat=' + $scope.selectedSubCategory.sys_id;
		}
		if ($scope.selectedItemObj && $scope.selectedItemObj.sys_id) {
			url_parms += '&cat_item=' + $scope.selectedItemObj.sys_id;
		}

		link_input.value = $location.absUrl().replace($location.url(), '') + '/sp?id=bu_sc_home' + url_parms;
		link_input.classList.remove('hidden');
		link_input.select();
		document.execCommand('copy');
		link_input.classList.add('hidden');
		spUtil.addInfoMessage('Copied to clipboard');
	}

	function getCategoryObject(sys_id) {
		for (var i = 0; i < c.data.categoriesList.length; i++) {
			if (c.data.categoriesList[i].sys_id == sys_id) {
				return c.data.categoriesList[i];
			}
		}
		return '';
	}

	function getSubcategoryObject(category_id, subcategory_id) {
		var cat = getCategoryObject(category_id);
		for (var i = 0; i < cat.subcategories.length; i++) {
			if (cat.subcategories[i].sys_id == subcategory_id) {
				return cat.subcategories[i];
			}
		}
		return '';
	}

	function getCatItemObject(category_id, subcategory_id, item_id) {
		var cat = getCategoryObject(category_id);
		if (subcategory_id == '') {
			for (var i = 0; i < cat.items.length; i++) {
				if (cat.items[i].sys_id == item_id) {
					return cat.items[i];
				}
			}
		}
		else {
			var subcat = getSubcategoryObject(category_id, subcategory_id);
			for (var j = 0; j < subcat.items.length; j++) {
				if (subcat.items[j].sys_id == item_id) {
					return subcat.items[j];
				}
			}
		}
		return '';
	}
