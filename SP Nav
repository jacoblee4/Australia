// HTML

<nav class="bu-navigator" ng-class="{'mobile-filters': mobileFilters}">
  <div class="actions">
    <button class="btn" ng-disabled="loading || !(selectedCategory || selectedItem)" ng-click="back()"> <i
        class="fa fa-arrow-left" aria-hidden="true"></i><span>Back</span> </button>
    <button class="btn" ng-click="reset()"><i class="fa fa-refresh" aria-hidden="true"></i><span>Start Over</span>
    </button>
    <button class="btn" ng-click="copyLinkToClipboard()"><i class="glyphicon glyphicon-link"
        aria-hidden="true"></i><span>Copy
        Link</span>
    </button>
    <a class="btn" href="?id=ppe_requests"><i class="fa fa-th-list" aria-hidden="true"></i> My requests</a>
     
    <button class="btn categories-toggle" ng-click="toggleCategories()" ng-class="{'active': mobileCategories}"
      style=""> <span>Categories</span><i class="fa fa-chevron-down"></i></button>
  </div>
  <input class="hidden" id="cat-item-link" />
  <div class="text-lg dropdowns" ng-show="totalItems.length > 0">
    <i class="fa fa-th" ng-click="changeView('grid')" aria-label="${Card View}" ng-class="{'active' : view == 'grid'}"
      uib-tooltip="${Grid View}" tooltip-placement="top" tooltip-enable="!isTouchDevice()" tooltip-append-to-body="true"
      aria-label="${Grid View}" tabindex="0"></i>
    <span class="m-l-sm m-r-sm "> | </span>
    <i class="fa fa-list-ul" ng-click="changeView('list')" aria-label="${List View}"
      ng-class="{'active' : view == 'list'}" uib-tooltip="${List View}" tooltip-placement="top"
      tooltip-enable="!isTouchDevice()" tooltip-append-to-body="true" aria-label="${List View}" tabindex="0"></i>
  </div>
  <div class="breadcrumbs">
    <span class="crumb " ng-if="selectedCategory">{{selectedCategory.title}} </span><span class="crumb"
      ng-if="selectedSubCategory">{{selectedSubCategory.title}} </span>
  </div>
</nav>
<section class="bu-stack"
  ng-class="{'has-mobilecategories':c.isChildMobile ,'has-nosubcategories':c.noSub,'has-subcategories':c.subcategories.length > 0 ,'has-childcategories':c.childcategories.length > 0,'mobile-categories':c.isMobile}">
  <div class="stack-wrapper no-border">
    <aside class="categories">
      <ul class="aside-list">
        <li ng-if="data.categoriesList.length > 0" ng-repeat="category in data.categoriesList track by $index"
          ng-click="selectCategory(category)" ng-class="{'cat-active': selectedCategory.sys_id == category.sys_id}"
          role="button">
          <img ng-if="category.homepage_image" src="{{category.homepage_image}}.iix" />
          <img ng-if="!category.homepage_image" src="646731c4dbce7b00d51c9ac5db96192a.iix" />
          <span class="category-label">{{category.title}}</span>
          <span ng-if="category.totalCount > 0" class="badge pull-right pointer">{{category.totalCount}}</span>
          <br />
          <div class="cat-desc"><small>{{category.description}}</small></div>
        </li>
      </ul>
    </aside>
    <aside class="subcategories">
      <ul class="aside-list">
        <li ng-if="c.subcategories.length > 0" ng-repeat="subcategory in c.subcategories track by $index"
          ng-click="selectSubCategory(subcategory)"
          ng-class="{'cat-active': selectedSubCategory.sys_id == subcategory.sys_id}" role="button">
          <img ng-if="category.homepage_image" src="{{category.homepage_image}}.iix" />
          <img ng-if="!category.homepage_image" src="646731c4dbce7b00d51c9ac5db96192a.iix" />
          <span class="category-label">{{subcategory.title}}</span>
          <span ng-if="subcategory.totalCount > 0" class="badge pull-right pointer">{{subcategory.totalCount}}</span>
          <div class="cat-desc"><small>{{subcategory.description}}</small></div>
        </li>
      </ul>
    </aside>
    <aside class="subchild-categories">
      <ul class="aside-list">
        <li ng-if="c.childcategories.length > 0" ng-repeat="child in c.childcategories track by $index"
          ng-click="selectChildCategory(child)" ng-class="{'cat-active': selectedChildCategory.sys_id == child.sys_id}"
          role="button">
          <img ng-if="child.homepage_image" src="{{child.homepage_image}}.iix" />
          <img ng-if="!child.homepage_image" src="646731c4dbce7b00d51c9ac5db96192a.iix" />
          <span class="category-label">{{child.title}}</span>
          <div class="cat-desc"><small>{{child.description}}</small></div>
        </li>
      </ul>
    </aside>
    <aside class="results">
      <div class="items-and-tags" ng-class="{'grid':view == 'grid','list': view == 'list'}">
        <div ng-hide="showItem" class="items">
          <div ng-if="data.showTitle" class="text-center col-md-12">
            <h2 class="h4 text-center m-t-none break-word"><span>Popular Items</span></h2>
          </div>
          <ul class="citems" ng-class="{'loading': loading}">
            <li ng-if="totalItems.length > 0"
              ng-repeat="item in filterData = (totalItems) track by item.sys_id"
              ng-click="selectItem(item)" ng-class="{'active': item.selected}" role="button">
              <img ng-src="{{::item.picture}}.iix" ng-if="::item.picture" alt="{{::item.name}}"
                class="m-r-sm m-b-sm item-image" />
              <img ng-if="::!item.picture" src="3f1cf21ddbce3300d51c9ac5db9619aa.iix" alt=""
                class="m-r-sm m-b-sm item-image" />
              <div class="item-details">
                <h3 class="item-label">{{::item.name}}</h3>
                <div class="item-summary">{{::item.short_description}}</div>
              </div>
            </li>
            <!--  <li ng-if="totalItems.length == 0" >
<div class="text-center"> 
<img class="img-responsive" src="5d570b95dbe23700d51c9ac5db96193f.iix"/>
</div>
</li>-->
          </ul>
          <div class="clearfix"></div>
          <!--div class="pull-right ps-page">
            <uib-pagination class="pagination-sm pagination" total-items="filterData.length" ng-model="page"
              ng-change="pageChanged()" previous-text="&lsaquo;" next-text="&rsaquo;" items-per-page=9>
            </uib-pagination>
          </div-->
        </div>
        <div ng-show="showItem" class="show-article">
          <div class="col-md-12">
            <div ng-repeat="itemWidget in c.itemWidgets">
              <sp-widget widget="itemWidget"></sp-widget>
            </div>
          </div>
        </div>
      </div>
    </aside>
  </div>
</section>




